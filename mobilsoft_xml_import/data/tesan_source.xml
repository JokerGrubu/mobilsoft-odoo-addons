<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Tesan B2B Portal - Web API Ürün Kaynağı -->
        <record id="xml_source_tesan" model="xml.product.source">
            <field name="name">Tesan Portal</field>
            <field name="sequence">5</field>
            <field name="active">True</field>

            <!-- Kaynak tipi ve şablon -->
            <field name="source_type">web</field>
            <field name="xml_template">tesan_web</field>
            <field name="xml_url">https://isortagim.tesan.com.tr</field>
            <field name="xml_username">info@jokergrubu.com</field>
            <field name="xml_password">XZsawq21-</field>

            <!-- İçeri aktarım seçenekleri -->
            <field name="create_new_products">True</field>
            <field name="update_price">True</field>
            <field name="update_stock">True</field>
            <field name="download_images">True</field>

            <!-- Kategori -->
            <field name="default_category_id" ref="product.product_category_goods"/>

        </record>

        <!-- Tesan Ürün Kategorileri Haritalaması -->
        <record id="xml_categ_mapping_tesan_mobil" model="xml.category.mapping">
            <field name="source_id" ref="xml_source_tesan"/>
            <field name="xml_category">Mobil Aksesuarlar</field>
            <field name="match_type">exact</field>
            <field name="odoo_category_id" ref="product.product_category_goods"/>
        </record>

        <record id="xml_categ_mapping_tesan_ses" model="xml.category.mapping">
            <field name="source_id" ref="xml_source_tesan"/>
            <field name="xml_category">Ses ve Video Çözümleri</field>
            <field name="match_type">exact</field>
            <field name="odoo_category_id" ref="product.product_category_goods"/>
        </record>

        <record id="xml_categ_mapping_tesan_tuketici" model="xml.category.mapping">
            <field name="source_id" ref="xml_source_tesan"/>
            <field name="xml_category">Tüketici Elektroniği</field>
            <field name="match_type">exact</field>
            <field name="odoo_category_id" ref="product.product_category_goods"/>
        </record>

        <record id="xml_categ_mapping_tesan_altyapi" model="xml.category.mapping">
            <field name="source_id" ref="xml_source_tesan"/>
            <field name="xml_category">Altyapı Çözümleri</field>
            <field name="match_type">exact</field>
            <field name="odoo_category_id" ref="product.product_category_goods"/>
