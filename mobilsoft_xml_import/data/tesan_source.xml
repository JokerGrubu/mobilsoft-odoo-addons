        </record>

        <record id="xml_categ_mapping_tesan_cctv" model="xml.category.mapping">
            <field name="source_id" ref="xml_source_tesan"/>
            <field name="xml_category">CCTV &amp; Güvenlik Çözümleri</field>
            <field name="match_type">exact</field>
            <field name="odoo_category_id" ref="product.product_category_goods"/>
        </record>

        <record id="xml_categ_mapping_tesan_yangin" model="xml.category.mapping">
            <field name="source_id" ref="xml_source_tesan"/>
            <field name="xml_category">Yangın Algılama ve İhbar Sistemleri</field>
            <field name="match_type">exact</field>
