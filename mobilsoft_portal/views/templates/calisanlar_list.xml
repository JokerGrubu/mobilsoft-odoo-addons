<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="calisanlar_list" name="MobilSoft Çalışanlar">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'masraflar'"/>

            <div class="p-3 p-md-4">
                <h4 class="mb-1 fw-bold"><i class="fa fa-users me-2 text-muted"/>Çalışanlar</h4>
                <small class="text-muted d-block mb-4"><t t-esc="len(users)"/> aktif kullanıcı</small>

                <div class="row g-3">
                    <t t-foreach="users" t-as="u" t-key="u.id">
                        <div class="col-md-6 col-lg-4">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-body py-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="ms-avatar" style="width:48px;height:48px;font-size:18px;">
                                            <t t-esc="(u.name or '?')[0].upper()"/>
                                        </div>
                                        <div>
                                            <div class="fw-bold"><t t-esc="u.name"/></div>
                                            <div class="text-muted small"><t t-esc="u.login"/></div>
                                            <div t-if="u.partner_id.phone" class="text-muted small">
                                                <i class="fa fa-phone me-1"/><t t-esc="u.partner_id.phone"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

</odoo>
