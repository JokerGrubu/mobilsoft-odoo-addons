<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="kullanici_form" name="MobilSoft Kullanıcı Formu">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'ayarlar'"/>

            <div class="p-3 p-md-4">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <a href="/mobilsoft/ayarlar/kullanicilar" class="btn btn-sm btn-outline-secondary">
                        <i class="fa fa-arrow-left"/>
                    </a>
                    <h4 class="mb-0 fw-bold">
                        <t t-if="is_new">Yeni Kullanıcı</t>
                        <t t-else="">Kullanıcı Düzenle</t>
                    </h4>
                </div>

                <t t-if="error">
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="fa fa-exclamation-triangle me-2"/><t t-esc="error"/>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"/>
                    </div>
                </t>

                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <form action="/mobilsoft/ayarlar/kullanicilar/kaydet" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="user_id" t-att-value="user_rec and user_rec.id or 0"/>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Ad Soyad *</label>
                                    <input type="text" name="name" class="form-control" required="required"
                                           t-att-value="user_rec and user_rec.name or ''"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">E-posta (Login) *</label>
                                    <input type="email" name="login" class="form-control" required="required"
                                           t-att-value="user_rec and user_rec.login or ''"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">
                                        <t t-if="is_new">Şifre *</t>
                                        <t t-else="">Yeni Şifre (boş bırakılırsa değişmez)</t>
                                    </label>
                                    <input type="password" name="password" class="form-control"
                                           t-att-required="is_new and 'required' or None"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Telefon</label>
                                    <input type="text" name="phone" class="form-control"
                                           t-att-value="user_rec and user_rec.partner_id.phone or ''"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Rol</label>
                                    <select name="role_id" class="form-select">
                                        <option value="">-- Rol seçin --</option>
                                        <t t-foreach="roles.items()" t-as="r" t-key="r[0]">
                                            <option t-att-value="r[0]"
                                                    t-att-selected="str(r[0]) == str(user_role_id)">
                                                <t t-esc="r[1].get('name', r[0]) if isinstance(r[1], dict) else r[1]"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-6 d-flex align-items-end">
                                    <div class="form-check">
                                        <input type="checkbox" name="active" class="form-check-input" id="chk_active"
                                               t-att-checked="(not user_rec or user_rec.active) and 'checked' or None"/>
                                        <label class="form-check-label fw-bold" for="chk_active">Aktif</label>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4 d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-save me-1"/>Kaydet
                                </button>
                                <a href="/mobilsoft/ayarlar/kullanicilar" class="btn btn-outline-secondary">İptal</a>
                            </div>
                        </form>

                        <!-- Password reset for existing users -->
                        <t t-if="not is_new and user_rec">
                            <hr class="my-4"/>
                            <h6 class="fw-bold">Şifre Sıfırla</h6>
                            <form t-attf-action="/mobilsoft/ayarlar/kullanicilar/#{user_rec.id}/sifre-sifirla" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="row g-2 align-items-end">
                                    <div class="col-md-4">
                                        <input type="password" name="new_password" class="form-control" placeholder="Yeni şifre" required="required"/>
                                    </div>
                                    <div class="col-auto">
                                        <button type="submit" class="btn btn-warning">
                                            <i class="fa fa-key me-1"/>Şifreyi Sıfırla
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
