<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="fatura_form" name="MobilSoft Fatura Form">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'faturalar'"/>

            <div class="p-3 p-md-4">
                <a href="/mobilsoft/faturalar" class="text-muted small text-decoration-none">
                    <i class="fa fa-arrow-left me-1"/>Faturalar
                </a>
                <h4 class="fw-bold mt-1 mb-4">
                    <i class="fa fa-plus me-2 text-muted"/>
                    <t t-esc="move_type_map.get(move_type, 'Fatura')"/>
                </h4>

                <t t-if="error">
                    <div class="alert alert-danger d-flex align-items-center py-2 small">
                        <i class="fa fa-exclamation-circle me-2"/><t t-esc="error"/>
                    </div>
                </t>

                <form action="/mobilsoft/faturalar/kaydet" method="post" id="invoiceForm">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="hidden" name="move_type" t-att-value="move_type"/>

                    <!-- Üst Bilgiler -->
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-header bg-white border-bottom py-3">
                            <h6 class="mb-0 fw-bold"><i class="fa fa-info-circle me-2 text-muted"/>Fatura Bilgileri</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label small fw-semibold">Cari *</label>
                                    <select name="partner_id" class="form-select" required="required">
                                        <option value="">Cari seçiniz...</option>
                                        <t t-foreach="partners" t-as="p" t-key="p.id">
                                            <option t-att-value="p.id"><t t-esc="p.name"/></option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-semibold">Fatura Tarihi</label>
                                    <input type="date" name="invoice_date" class="form-control"/>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small fw-semibold">Referans</label>
                                    <input type="text" name="ref" class="form-control" placeholder="Sipariş no..."/>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small fw-semibold">Para Birimi</label>
                                    <select name="currency_id" class="form-select">
                                        <t t-foreach="currencies" t-as="cur" t-key="cur.id">
                                            <option t-att-value="cur.id"
                                                    t-att-selected="cur.id == company_currency.id">
                                                <t t-esc="cur.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Fatura Satırları -->
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                            <h6 class="mb-0 fw-bold"><i class="fa fa-list me-2 text-muted"/>Kalemler</h6>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="addInvoiceLine()">
                                <i class="fa fa-plus me-1"/>Satır Ekle
                            </button>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm mb-0 align-middle" id="invoiceLines">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:30%;">Ürün</th>
                                        <th>Açıklama</th>
                                        <th style="width:80px;" class="text-end">Miktar</th>
                                        <th style="width:100px;" class="text-end">Fiyat</th>
                                        <th style="width:120px;">KDV</th>
                                        <th style="width:40px;"/>
                                    </tr>
                                </thead>
                                <tbody id="invoiceLinesBody">
                                    <!-- İlk satır -->
                                    <tr class="invoice-line" data-idx="0">
                                        <td>
                                            <select name="line_product_0" class="form-select form-select-sm"
                                                    onchange="onProductChange(this, 0)">
                                                <option value="0">Serbest kalem</option>
                                                <t t-foreach="products" t-as="pr" t-key="pr.id">
                                                    <option t-att-value="pr.id"
                                                            t-att-data-price="pr.lst_price"
                                                            t-att-data-name="pr.display_name">
                                                        <t t-esc="pr.display_name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </td>
                                        <td>
                                            <input type="text" name="line_desc_0" class="form-control form-control-sm"
                                                   placeholder="Açıklama"/>
                                        </td>
                                        <td>
                                            <input type="number" name="line_qty_0" class="form-control form-control-sm text-end"
                                                   value="1" min="0.01" step="0.01"/>
                                        </td>
                                        <td>
                                            <input type="number" name="line_price_0" class="form-control form-control-sm text-end"
                                                   value="0" step="0.01"/>
                                        </td>
                                        <td>
                                            <select name="line_tax_0" class="form-select form-select-sm">
                                                <option value="0">KDV yok</option>
                                                <t t-foreach="taxes" t-as="tax" t-key="tax.id">
                                                    <option t-att-value="tax.id"><t t-esc="tax.name"/></option>
                                                </t>
                                            </select>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1"
                                                    onclick="removeLine(this)">
                                                <i class="fa fa-times"/>
                                            </button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="/mobilsoft/faturalar" class="btn btn-outline-secondary">
                            <i class="fa fa-times me-1"/>İptal
                        </a>
                        <button type="submit" class="btn ms-btn-brand px-4">
                            <i class="fa fa-save me-1"/>Taslak Kaydet
                        </button>
                    </div>
                </form>
            </div>

            <script>
                var lineCounter = 1;

                function addInvoiceLine() {
                    var tbody = document.getElementById('invoiceLinesBody');
                    var firstRow = tbody.querySelector('.invoice-line');
                    var newRow = firstRow.cloneNode(true);
                    var idx = lineCounter++;

                    newRow.setAttribute('data-idx', idx);

                    // Update names
                    newRow.querySelectorAll('[name]').forEach(function(el) {
                        el.name = el.name.replace(/_\d+$/, '_' + idx);
                        if (el.tagName === 'INPUT') el.value = el.type === 'number' ? (el.name.includes('qty') ? '1' : '0') : '';
                        if (el.tagName === 'SELECT') el.selectedIndex = 0;
                    });

                    tbody.appendChild(newRow);
                }

                function removeLine(btn) {
                    var tbody = document.getElementById('invoiceLinesBody');
                    if (tbody.querySelectorAll('.invoice-line').length > 1) {
                        btn.closest('tr').remove();
                    }
                }

                function onProductChange(sel, idx) {
                    var opt = sel.options[sel.selectedIndex];
                    var price = opt.getAttribute('data-price');
                    var name = opt.getAttribute('data-name');
                    if (price) {
                        document.querySelector('[name="line_price_' + idx + '"]').value = parseFloat(price).toFixed(2);
                    }
                    if (name) {
                        document.querySelector('[name="line_desc_' + idx + '"]').value = name;
                    }
                }
            </script>
        </t>
    </template>

</odoo>
