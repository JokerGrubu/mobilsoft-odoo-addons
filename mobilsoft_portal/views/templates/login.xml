<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="login_page" name="MobilSoft Login">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>

            <div class="ms-auth">
                <!-- Branding Section -->
                <div class="ms-auth__brand d-none d-lg-flex">
                    <div class="ms-auth__brand-content">
                        <div class="mb-4">
                            <i class="fa fa-shield" style="font-size:3.5rem; color:var(--ms-secondary);"/>
                        </div>
                        <h1>Geleceğin ERP Deneyimi</h1>
                        <p>
                            İşletmenizi dijital dünyada bir adım öne taşıyın. 
                            MobilSoft ile finans, stok ve e-ticaret süreçlerinizi 
                            tek bir akıllı platformdan yönetin.
                        </p>
                        <div class="mt-5 d-flex flex-wrap gap-4">
                            <div class="d-flex align-items-center gap-2">
                                <i class="fa fa-check-circle text-success"/>
                                <span>Akıllı Raporlama</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <i class="fa fa-check-circle text-success"/>
                                <span>Bulut Altyapı</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <i class="fa fa-check-circle text-success"/>
                                <span>7/24 Destek</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Section -->
                <div class="ms-auth__form-area">
                    <div class="ms-auth__card">
                        <div class="mb-5 text-center">
                            <h2 class="fw-bold text-dark">Giriş Yapın</h2>
                            <p class="text-muted">Kullanıcı bilgilerinizle oturum açın</p>
                        </div>

                        <t t-if="error">
                            <div class="alert alert-danger mb-4 rounded-3 border-0" role="alert">
                                <i class="fa fa-exclamation-triangle me-2"/>
                                Bilgileriniz hatalı, lütfen kontrol edin.
                            </div>
                        </t>

                        <form action="/mobilsoft/login/submit" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            
                            <div class="mb-4">
                                <label class="form-label mb-2">E-posta Adresi</label>
                                <input type="email" name="login" class="form-control" 
                                       placeholder="ad.soyad@jokergrubu.com" required="required"
                                       t-att-value="login" autofocus="autofocus"/>
                            </div>

                            <div class="mb-4">
                                <div class="d-flex justify-content-between">
                                    <label class="form-label mb-2">Şifre</label>
                                    <a href="#" class="small text-decoration-none" style="color:var(--ms-primary);">Unuttum?</a>
                                </div>
                                <input type="password" name="password" class="form-control" 
                                       placeholder="••••••••" required="required"/>
                            </div>

                            <button type="submit" class="btn ms-btn-brand w-100 py-3 mt-2">
                                Sisteme Giriş Yap
                            </button>
                        </form>

                        <div class="mt-5 pt-4 border-top text-center">
                            <p class="text-muted small">Henüz hesabınız yok mu?</p>
                            <a href="/mobilsoft/register" class="btn btn-outline-secondary w-100 py-2 fw-semibold">
                                Ücretsiz Denemeye Başla
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
