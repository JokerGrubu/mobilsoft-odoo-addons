<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="login_page" name="MobilSoft Login">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>

            <div class="ms-auth">
                <!-- Sol: Branding -->
                <div class="ms-auth__brand d-none d-lg-flex">
                    <div class="ms-auth__brand-content">
                        <div class="mb-4">
                            <i class="fa fa-building-o" style="font-size:48px; opacity:0.9;"/>
                        </div>
                        <h1 class="fw-bold mb-3" style="font-size:2.2rem;">MobilSoft</h1>
                        <p class="mb-4" style="font-size:1.1rem; opacity:0.85; line-height:1.6;">
                            Ön muhasebe, fatura, stok, kasa ve pazaryeri yönetimini
                            tek platformdan yapın.
                        </p>
                        <div class="d-flex flex-column gap-2" style="opacity:0.75; font-size:0.9rem;">
                            <div><i class="fa fa-check-circle me-2"/>e-Fatura / e-Arşiv / e-İrsaliye</div>
                            <div><i class="fa fa-check-circle me-2"/>Cari, Stok, Kasa/Banka Takibi</div>
                            <div><i class="fa fa-check-circle me-2"/>CepteTedarik B2B Pazaryeri</div>
                            <div><i class="fa fa-check-circle me-2"/>Çoklu Şirket Yönetimi</div>
                            <div><i class="fa fa-check-circle me-2"/>POS Kasa Satışı</div>
                        </div>
                    </div>
                </div>

                <!-- Sağ: Login Formu -->
                <div class="ms-auth__form-area">
                    <div class="ms-auth__card">
                        <!-- Mobil logo -->
                        <div class="text-center mb-4 d-lg-none">
                            <i class="fa fa-building-o" style="font-size:36px; color:var(--ms-brand);"/>
                        </div>

                        <h3 class="fw-bold mb-1">Giriş Yap</h3>
                        <p class="text-muted small mb-4">İşletme yönetim panelinize erişin</p>

                        <t t-if="error">
                            <div class="alert alert-danger d-flex align-items-center py-2 small" role="alert">
                                <i class="fa fa-exclamation-circle me-2"/>
                                E-posta veya şifre hatalı. Lütfen tekrar deneyin.
                            </div>
                        </t>

                        <form action="/mobilsoft/login/submit" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="redirect" t-att-value="redirect"/>

                            <div class="mb-3">
                                <label class="form-label small fw-semibold">
                                    <i class="fa fa-envelope-o me-1 text-muted"/>E-posta
                                </label>
                                <input type="email" name="login" class="form-control form-control-lg"
                                       placeholder="ornek@sirket.com" required="required"
                                       t-att-value="login" autofocus="autofocus"/>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-semibold">
                                    <i class="fa fa-lock me-1 text-muted"/>Şifre
                                </label>
                                <input type="password" name="password" class="form-control form-control-lg"
                                       placeholder="••••••••" required="required"/>
                            </div>

                            <button type="submit" class="btn ms-btn-brand w-100 fw-semibold py-2 mb-3">
                                <i class="fa fa-sign-in me-1"/>Giriş Yap
                            </button>
                        </form>

                        <div class="text-center">
                            <span class="text-muted small">Henüz hesabınız yok mu?</span>
                            <a href="/mobilsoft/register" class="small fw-semibold ms-link">Ücretsiz Kayıt Olun</a>
                        </div>
                    </div>

                    <div class="text-center mt-3">
                        <small class="text-muted">© 2026 MobilSoft — Joker Grubu</small>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
