<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="faturalar_list" name="MobilSoft Faturalar Liste">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'faturalar'"/>

            <div class="p-3 p-md-4">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                    <div>
                        <h4 class="mb-0 fw-bold"><i class="fa fa-file-text-o me-2 text-muted"/>Faturalar</h4>
                        <small class="text-muted">
                            <t t-esc="satis_count"/> satış, <t t-esc="alis_count"/> alış
                            <span t-if="bekleyen > 0" class="text-danger ms-2">
                                <i class="fa fa-clock-o me-1"/><t t-esc="bekleyen"/> ödenmemiş
                            </span>
                        </small>
                    </div>
                    <div class="d-flex gap-2">
                    <a href="/mobilsoft/export/faturalar" class="btn btn-sm btn-outline-success">
                        <i class="fa fa-file-excel-o me-1"/>Excel
                    </a>
                    <div class="dropdown">
                        <button class="btn btn-sm ms-btn-brand dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="fa fa-plus me-1"/>Yeni Fatura
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/mobilsoft/faturalar/yeni?move_type=out_invoice"><i class="fa fa-arrow-up me-2 text-success"/>Satış Faturası</a></li>
                            <li><a class="dropdown-item" href="/mobilsoft/faturalar/yeni?move_type=in_invoice"><i class="fa fa-arrow-down me-2 text-warning"/>Alış Faturası</a></li>
                            <li><hr class="dropdown-divider"/></li>
                            <li><a class="dropdown-item" href="/mobilsoft/faturalar/yeni?move_type=out_refund"><i class="fa fa-undo me-2 text-danger"/>Satış İadesi</a></li>
                            <li><a class="dropdown-item" href="/mobilsoft/faturalar/yeni?move_type=in_refund"><i class="fa fa-undo me-2 text-info"/>Alış İadesi</a></li>
                        </ul>
                    </div>
                    </div>
                </div>

                <!-- Sekmeler -->
                <ul class="nav nav-tabs mb-3">
                    <li class="nav-item">
                        <a t-attf-class="nav-link #{'active' if tab == 'satis' else ''}"
                           t-attf-href="/mobilsoft/faturalar?tab=satis&amp;q=#{q}&amp;state=#{state_filter}">
                            <i class="fa fa-arrow-up me-1"/>Satış
                            <span class="badge bg-secondary ms-1"><t t-esc="satis_count"/></span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a t-attf-class="nav-link #{'active' if tab == 'alis' else ''}"
                           t-attf-href="/mobilsoft/faturalar?tab=alis&amp;q=#{q}&amp;state=#{state_filter}">
                            <i class="fa fa-arrow-down me-1"/>Alış
                            <span class="badge bg-secondary ms-1"><t t-esc="alis_count"/></span>
                        </a>
                    </li>
                </ul>

                <!-- Arama + Filtre -->
                <form method="get" action="/mobilsoft/faturalar" class="mb-3">
                    <input type="hidden" name="tab" t-att-value="tab"/>
                    <div class="row g-2">
                        <div class="col-md-5">
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="fa fa-search text-muted"/></span>
                                <input type="text" name="q" class="form-control"
                                       placeholder="Fatura no, cari veya referans..." t-att-value="q"/>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <select name="state" class="form-select">
                                <option value="">Tüm Durumlar</option>
                                <option value="draft" t-att-selected="'selected' if state_filter == 'draft' else None">Taslak</option>
                                <option value="posted" t-att-selected="'selected' if state_filter == 'posted' else None">Onaylı</option>
                                <option value="not_paid" t-att-selected="'selected' if state_filter == 'not_paid' else None">Ödenmemiş</option>
                                <option value="paid" t-att-selected="'selected' if state_filter == 'paid' else None">Ödenmiş</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-outline-secondary w-100">
                                <i class="fa fa-filter me-1"/>Filtrele
                            </button>
                        </div>
                    </div>
                </form>

                <!-- Tablo -->
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Numara</th>
                                    <th>Cari</th>
                                    <th class="d-none d-md-table-cell">Tarih</th>
                                    <th>Tür</th>
                                    <th class="text-end">Tutar</th>
                                    <th>Durum</th>
                                    <th style="width:50px;"/>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="not invoices">
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-5">
                                            <i class="fa fa-inbox fa-2x d-block mb-2"/>Fatura bulunamadı.
                                        </td>
                                    </tr>
                                </t>
                                <t t-foreach="invoices" t-as="inv" t-key="inv.id">
                                    <tr class="ms-table-row" style="cursor:pointer;"
                                        t-attf-onclick="window.location='/mobilsoft/faturalar/#{inv.id}'">
                                        <td class="fw-semibold small">
                                            <t t-esc="inv.name or 'Taslak'"/>
                                        </td>
                                        <td class="small"><t t-esc="inv.partner_id.name or '-'"/></td>
                                        <td class="d-none d-md-table-cell small text-muted">
                                            <t t-esc="inv.invoice_date or inv.date"/>
                                        </td>
                                        <td>
                                            <span t-if="inv.move_type == 'out_invoice'" class="badge bg-success-subtle text-success">Satış</span>
                                            <span t-if="inv.move_type == 'in_invoice'" class="badge bg-warning-subtle text-warning">Alış</span>
                                            <span t-if="inv.move_type == 'out_refund'" class="badge bg-danger-subtle text-danger">İade (S)</span>
                                            <span t-if="inv.move_type == 'in_refund'" class="badge bg-info-subtle text-info">İade (A)</span>
                                        </td>
                                        <td class="text-end fw-bold small">
                                            ₺ <t t-esc="'{:,.2f}'.format(inv.amount_total)"/>
                                        </td>
                                        <td>
                                            <span t-if="inv.state == 'draft'" class="badge bg-secondary">Taslak</span>
                                            <span t-if="inv.state == 'posted' and inv.payment_state == 'paid'" class="badge bg-success">Ödendi</span>
                                            <span t-if="inv.state == 'posted' and inv.payment_state == 'partial'" class="badge bg-warning">Kısmi</span>
                                            <span t-if="inv.state == 'posted' and inv.payment_state == 'not_paid'" class="badge bg-danger">Ödenmedi</span>
                                            <span t-if="inv.state == 'cancel'" class="badge bg-dark">İptal</span>
                                        </td>
                                        <td class="text-end">
                                            <a t-attf-href="/mobilsoft/faturalar/#{inv.id}" class="btn btn-sm btn-outline-secondary py-0 px-2"
                                               onclick="event.stopPropagation();">
                                                <i class="fa fa-chevron-right"/>
                                            </a>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Sayfalama -->
                <t t-if="page_count > 1">
                    <nav class="mt-3 d-flex justify-content-center">
                        <ul class="pagination pagination-sm mb-0">
                            <li t-attf-class="page-item #{'disabled' if page_num == 1 else ''}">
                                <a class="page-link" t-attf-href="/mobilsoft/faturalar?tab=#{tab}&amp;q=#{q}&amp;state=#{state_filter}&amp;page=#{page_num - 1}">
                                    <i class="fa fa-chevron-left"/>
                                </a>
                            </li>
                            <t t-foreach="page_range" t-as="pg" t-key="pg">
                                <li t-attf-class="page-item #{'active' if pg == page_num else ''}">
                                    <a class="page-link" t-attf-href="/mobilsoft/faturalar?tab=#{tab}&amp;q=#{q}&amp;state=#{state_filter}&amp;page=#{pg}">
                                        <t t-esc="pg"/>
                                    </a>
                                </li>
                            </t>
                            <li t-attf-class="page-item #{'disabled' if page_num == page_count else ''}">
                                <a class="page-link" t-attf-href="/mobilsoft/faturalar?tab=#{tab}&amp;q=#{q}&amp;state=#{state_filter}&amp;page=#{page_num + 1}">
                                    <i class="fa fa-chevron-right"/>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </t>

                <div class="text-center mt-2">
                    <small class="text-muted">
                        Toplam <t t-esc="total"/> fatura — Sayfa <t t-esc="page_num"/> / <t t-esc="page_count"/>
                    </small>
                </div>
            </div>
        </t>
    </template>

</odoo>
