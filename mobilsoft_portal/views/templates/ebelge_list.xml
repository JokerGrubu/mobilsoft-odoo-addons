<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="ebelge_list" name="MobilSoft e-Belge Listesi">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'ebelge'"/>

            <div class="p-3 p-md-4">
                <!-- Modül yüklü değilse uyarı -->
                <t t-if="module_missing">
                    <div class="text-center py-5">
                        <i class="fa fa-exclamation-triangle fa-3x text-warning mb-3 d-block"/>
                        <h5>e-Belge modülü yüklü değil</h5>
                        <p class="text-muted">mobilsoft_qnb_efatura modülünü yükleyin.</p>
                    </div>
                </t>

                <t t-if="not module_missing">
                    <!-- Başlık -->
                    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                        <div>
                            <h4 class="mb-0 fw-bold"><i class="fa fa-file-code-o me-2 text-muted"/>e-Belgeler</h4>
                            <span class="text-muted small"><t t-esc="total"/> kayıt</span>
                        </div>
                    </div>

                    <!-- KPI -->
                    <div class="row g-3 mb-4">
                        <div class="col-6 col-md-3">
                            <div class="card border-0 shadow-sm ms-kpi-card ms-kpi-card--teal">
                                <div class="card-body py-3 text-center">
                                    <div class="text-muted small">Giden Belge</div>
                                    <div class="fw-bold fs-5"><t t-esc="giden_count"/></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card border-0 shadow-sm ms-kpi-card ms-kpi-card--warning">
                                <div class="card-body py-3 text-center">
                                    <div class="text-muted small">Gelen Belge</div>
                                    <div class="fw-bold fs-5"><t t-esc="gelen_count"/></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Tabs + Filtre -->
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-bottom py-0 d-flex justify-content-between align-items-center flex-wrap">
                            <ul class="nav nav-tabs border-0">
                                <li class="nav-item">
                                    <a t-attf-class="nav-link border-0 py-3 #{'active fw-bold' if tab == 'giden' else 'text-muted'}"
                                       href="/mobilsoft/ebelge?tab=giden">
                                        Giden <span class="badge bg-primary-subtle text-primary ms-1"><t t-esc="giden_count"/></span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a t-attf-class="nav-link border-0 py-3 #{'active fw-bold' if tab == 'gelen' else 'text-muted'}"
                                       href="/mobilsoft/ebelge?tab=gelen">
                                        Gelen <span class="badge bg-warning-subtle text-warning ms-1"><t t-esc="gelen_count"/></span>
                                    </a>
                                </li>
                            </ul>
                            <form method="get" action="/mobilsoft/ebelge" class="d-flex gap-2 py-2">
                                <input type="hidden" name="tab" t-att-value="tab"/>
                                <select name="doc_type" class="form-select form-select-sm" style="width:120px;">
                                    <option value="">Tümü</option>
                                    <option value="efatura" t-att-selected="doc_type_filter == 'efatura'">e-Fatura</option>
                                    <option value="earsiv" t-att-selected="doc_type_filter == 'earsiv'">e-Arşiv</option>
                                    <option value="eirsaliye" t-att-selected="doc_type_filter == 'eirsaliye'">e-İrsaliye</option>
                                </select>
                                <input type="text" name="q" t-att-value="q" class="form-control form-control-sm" placeholder="Ara..." style="width:140px;"/>
                                <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="fa fa-search"/></button>
                            </form>
                        </div>

                        <!-- Tablo -->
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Belge No</th>
                                        <th>Tür</th>
                                        <th>Cari</th>
                                        <th>Tarih</th>
                                        <th class="text-end">Tutar</th>
                                        <th class="text-center">Durum</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="documents" t-as="doc" t-key="doc.id">
                                        <tr class="ms-table-row" style="cursor:pointer;" t-attf-onclick="window.location='/mobilsoft/ebelge/#{doc.id}'">
                                            <td class="small fw-semibold"><t t-esc="doc.name"/></td>
                                            <td class="small">
                                                <span class="badge bg-light text-dark">
                                                    <t t-esc="doc_type_map.get(doc.document_type, doc.document_type)"/>
                                                </span>
                                            </td>
                                            <td class="small"><t t-esc="doc.partner_id.name or '-'"/></td>
                                            <td class="small text-muted"><t t-esc="doc.document_date or '-'"/></td>
                                            <td class="text-end fw-bold small">₺ <t t-esc="'{:,.2f}'.format(doc.amount_total or 0)"/></td>
                                            <td class="text-center">
                                                <span t-attf-class="badge #{doc_state_badge.get(doc.state, 'bg-secondary')}">
                                                    <t t-esc="doc_state_map.get(doc.state, doc.state)"/>
                                                </span>
                                            </td>
                                        </tr>
                                    </t>
                                    <tr t-if="not documents">
                                        <td colspan="6" class="text-center text-muted py-4">
                                            <i class="fa fa-inbox fa-2x d-block mb-2 opacity-50"/>
                                            e-Belge bulunamadı
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        <t t-if="page_count > 1">
                            <div class="card-footer bg-white d-flex justify-content-center">
                                <nav>
                                    <ul class="pagination pagination-sm mb-0">
                                        <li t-attf-class="page-item #{'disabled' if page_num == 1 else ''}">
                                            <a class="page-link" t-attf-href="/mobilsoft/ebelge?tab=#{tab}&amp;doc_type=#{doc_type_filter}&amp;q=#{q}&amp;page=#{page_num - 1}">‹</a>
                                        </li>
                                        <t t-foreach="page_range" t-as="pg" t-key="pg">
                                            <li t-attf-class="page-item #{'active' if pg == page_num else ''}">
                                                <a class="page-link" t-attf-href="/mobilsoft/ebelge?tab=#{tab}&amp;doc_type=#{doc_type_filter}&amp;q=#{q}&amp;page=#{pg}"><t t-esc="pg"/></a>
                                            </li>
                                        </t>
                                        <li t-attf-class="page-item #{'disabled' if page_num == page_count else ''}">
                                            <a class="page-link" t-attf-href="/mobilsoft/ebelge?tab=#{tab}&amp;doc_type=#{doc_type_filter}&amp;q=#{q}&amp;page=#{page_num + 1}">›</a>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        </t>
                    </div>
                </t>
            </div>
        </t>
    </template>

</odoo>
