<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="urun_stok" name="MobilSoft Ürün Stok Hareketleri">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'urunler'"/>

            <div class="p-3 p-md-4">
                <!-- Breadcrumb -->
                <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
                    <div>
                        <a t-attf-href="/mobilsoft/urunler/#{product.id}" class="text-muted small text-decoration-none">
                            <i class="fa fa-arrow-left me-1"/><t t-esc="product.name"/>
                        </a>
                        <h4 class="fw-bold mt-1 mb-0">
                            <i class="fa fa-exchange me-2 text-muted"/>Stok Hareketleri
                        </h4>
                    </div>
                    <div class="card border-0 shadow-sm">
                        <div class="card-body py-2 px-3 text-center">
                            <div class="text-muted" style="font-size:11px;">Mevcut Stok</div>
                            <div t-attf-class="fw-bold fs-5 #{('text-success' if total_qty > 0 else 'text-danger')}">
                                <t t-esc="'{:,.0f}'.format(total_qty)"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Hareket Tablosu -->
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Tarih</th>
                                    <th>Referans</th>
                                    <th>Kaynak</th>
                                    <th>Nereden</th>
                                    <th>Nereye</th>
                                    <th class="text-end">Miktar</th>
                                    <th>Birim</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="not move_lines">
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">
                                            <i class="fa fa-inbox fa-2x d-block mb-2"/>
                                            Stok hareketi bulunamadı.
                                        </td>
                                    </tr>
                                </t>
                                <t t-foreach="move_lines" t-as="ml" t-key="ml_index">
                                    <tr>
                                        <td class="small text-muted"><t t-esc="ml['date']"/></td>
                                        <td class="small fw-semibold"><t t-esc="ml['reference']"/></td>
                                        <td class="small text-muted"><t t-esc="ml['origin']"/></td>
                                        <td class="small"><t t-esc="ml['from']"/></td>
                                        <td class="small"><t t-esc="ml['to']"/></td>
                                        <td class="text-end fw-semibold small"><t t-esc="'{:,.2f}'.format(ml['qty'])"/></td>
                                        <td class="small text-muted"><t t-esc="ml['uom']"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
