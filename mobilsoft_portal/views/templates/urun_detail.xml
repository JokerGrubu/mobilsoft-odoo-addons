<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="urun_detail" name="MobilSoft Ürün Detay">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'urunler'"/>

            <div class="p-3 p-md-4">
                <!-- Breadcrumb -->
                <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
                    <div>
                        <a href="/mobilsoft/urunler" class="text-muted small text-decoration-none">
                            <i class="fa fa-arrow-left me-1"/>Ürünler
                        </a>
                        <h4 class="mb-0 fw-bold mt-1"><t t-esc="product.name"/></h4>
                        <div class="d-flex gap-2 mt-1">
                            <span t-if="product.default_code" class="badge bg-light text-muted">
                                <i class="fa fa-tag me-1"/><t t-esc="product.default_code"/>
                            </span>
                            <span t-if="product.barcode" class="badge bg-light text-muted">
                                <i class="fa fa-barcode me-1"/><t t-esc="product.barcode"/>
                            </span>
                            <span class="badge bg-primary-subtle text-primary">
                                <t t-if="product.type == 'consu'">Stoklanan</t>
                                <t t-elif="product.type == 'service'">Hizmet</t>
                                <t t-else="">Sarf</t>
                            </span>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a t-attf-href="/mobilsoft/urunler/#{product.id}/stok" class="btn btn-sm btn-outline-secondary">
                            <i class="fa fa-exchange me-1"/>Stok Hareketleri
                        </a>
                        <a t-attf-href="/mobilsoft/urunler/#{product.id}/duzenle" class="btn btn-sm ms-btn-brand">
                            <i class="fa fa-pencil me-1"/>Düzenle
                        </a>
                    </div>
                </div>

                <div class="row g-3">
                    <!-- Sol: Ürün Bilgileri -->
                    <div class="col-md-5">
                        <!-- Resim -->
                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-body text-center py-4">
                                <t t-if="product.image_256">
                                    <img t-attf-src="data:image/png;base64,#{product.image_256.decode()}"
                                         class="img-fluid rounded" style="max-height:200px;" alt=""/>
                                </t>
                                <t t-else="">
                                    <div class="text-muted py-4">
                                        <i class="fa fa-image fa-4x"/>
                                        <div class="mt-2 small">Resim yok</div>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <!-- Fiyat + Stok -->
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <div class="card border-0 shadow-sm ms-kpi-card ms-kpi-card--success">
                                    <div class="card-body py-3 text-center">
                                        <div class="text-muted small">Satış Fiyatı</div>
                                        <div class="fw-bold fs-5 text-success">
                                            ₺ <t t-esc="'{:,.2f}'.format(product.list_price)"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="card border-0 shadow-sm ms-kpi-card ms-kpi-card--teal">
                                    <div class="card-body py-3 text-center">
                                        <div class="text-muted small">Stok</div>
                                        <div t-attf-class="fw-bold fs-5 #{('text-success' if total_qty > 0 else 'text-danger')}">
                                            <t t-esc="'{:,.0f}'.format(total_qty)"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Detay Bilgileri -->
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold"><i class="fa fa-info-circle me-2 text-muted"/>Bilgiler</h6>
                            </div>
                            <div class="card-body">
                                <table class="table table-borderless table-sm mb-0">
                                    <tbody>
                                        <tr>
                                            <td class="text-muted" style="width:120px;">Kategori</td>
                                            <td class="fw-semibold"><t t-esc="product.categ_id.complete_name or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Birim</td>
                                            <td><t t-esc="product.uom_id.name or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Maliyet</td>
                                            <td>₺ <t t-esc="'{:,.2f}'.format(product.standard_price)"/></td>
                                        </tr>
                                        <tr t-if="product.description_sale">
                                            <td class="text-muted">Açıklama</td>
                                            <td class="small"><t t-esc="product.description_sale"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Sağ: Son Satışlar -->
                    <div class="col-md-7">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold"><i class="fa fa-shopping-cart me-2 text-muted"/>Son Satışlar</h6>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="recent_sales">
                                    <table class="table table-hover table-sm mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Tarih</th>
                                                <th>Müşteri</th>
                                                <th class="text-end">Miktar</th>
                                                <th class="text-end">Fiyat</th>
                                                <th class="text-end">Toplam</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="recent_sales" t-as="sale" t-key="sale_index">
                                                <tr>
                                                    <td class="small text-muted"><t t-esc="sale['date']"/></td>
                                                    <td class="small fw-semibold"><t t-esc="sale['partner']"/></td>
                                                    <td class="text-end small"><t t-esc="'{:,.0f}'.format(sale['qty'])"/></td>
                                                    <td class="text-end small">₺ <t t-esc="'{:,.2f}'.format(sale['price'])"/></td>
                                                    <td class="text-end small fw-semibold">₺ <t t-esc="'{:,.2f}'.format(sale['total'])"/></td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <div class="text-muted text-center py-4">
                                        <i class="fa fa-inbox fa-2x d-block mb-2"/>
                                        Henüz satış yok
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
