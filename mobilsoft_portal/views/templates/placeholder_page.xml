<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="placeholder_page" name="Placeholder Page">
        <t t-call="mobilsoft_portal.portal_layout">
            <div class="container-fluid py-4">
                <div class="row justify-content-center">
                    <div class="col-md-6 text-center py-5">
                        <i t-att-class="'fa ' + page_icon + ' text-muted'" style="font-size:64px;"/>
                        <h3 class="mt-4" t-esc="page_title"/>
                        <p class="text-muted mt-3" t-esc="page_desc"/>
                        <a href="/mobilsoft/dashboard" class="btn btn-primary mt-3">
                            <i class="fa fa-home me-1"/>Ana Sayfaya Dön
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
