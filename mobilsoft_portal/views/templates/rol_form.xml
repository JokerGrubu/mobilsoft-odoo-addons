<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="rol_form" name="MobilSoft Rol Formu">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'ayarlar'"/>

            <div class="p-3 p-md-4">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <a href="/mobilsoft/ayarlar/roller" class="btn btn-sm btn-outline-secondary">
                        <i class="fa fa-arrow-left"/>
                    </a>
                    <h4 class="mb-0 fw-bold">
                        <t t-if="is_new">Yeni Rol</t>
                        <t t-else="">Rol Düzenle</t>
                    </h4>
                </div>

                <t t-if="error">
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="fa fa-exclamation-triangle me-2"/><t t-esc="error"/>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"/>
                    </div>
                </t>

                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <form action="/mobilsoft/ayarlar/roller/kaydet" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="role_id" t-att-value="role_id or ''"/>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Rol Adı *</label>
                                <input type="text" name="name" class="form-control" required="required"
                                       placeholder="ör: Muhasebeci, Satış Temsilcisi, Yönetici"
                                       t-att-value="role and role.get('name', '') or ''"/>
                            </div>

                            <h6 class="fw-bold mt-4 mb-3">İzinler</h6>
                            <div class="table-responsive">
                                <table class="table table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Modül</th>
                                            <th>Erişim Seviyesi</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="modules" t-as="mod" t-key="mod[0]">
                                            <tr>
                                                <td class="fw-bold"><t t-esc="mod[1]"/></td>
                                                <td>
                                                    <select t-attf-name="perm_#{mod[0]}" class="form-select form-select-sm">
                                                        <option value="none"
                                                                t-att-selected="not perms.get(mod[0])">Erişim Yok</option>
                                                        <t t-foreach="levels.get(mod[0], [])" t-as="lv" t-key="lv">
                                                            <option t-att-value="lv"
                                                                    t-att-selected="perms.get(mod[0]) == lv">
                                                                <t t-if="lv == 'view'">Görüntüleme</t>
                                                                <t t-if="lv == 'edit'">Görüntüleme + Düzenleme</t>
                                                                <t t-if="lv == 'create'">Görüntüleme + Oluşturma</t>
                                                                <t t-if="lv == 'access'">Tam Erişim</t>
                                                            </option>
                                                        </t>
                                                    </select>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>

                            <div class="mt-4 d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-save me-1"/>Kaydet
                                </button>
                                <a href="/mobilsoft/ayarlar/roller" class="btn btn-outline-secondary">İptal</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
