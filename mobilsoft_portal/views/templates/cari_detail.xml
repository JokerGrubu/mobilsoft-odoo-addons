<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="cari_detail" name="MobilSoft Cari Detay">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'cariler'"/>

            <div class="p-3 p-md-4">
                <!-- Breadcrumb + Aksiyonlar -->
                <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
                    <div>
                        <a href="/mobilsoft/cariler" class="text-muted small text-decoration-none">
                            <i class="fa fa-arrow-left me-1"/>Cariler
                        </a>
                        <h4 class="mb-0 fw-bold mt-1">
                            <t t-esc="partner.name"/>
                        </h4>
                        <div class="d-flex gap-2 mt-1">
                            <span t-if="partner.customer_rank > 0" class="badge bg-primary-subtle text-primary">
                                <i class="fa fa-user me-1"/>Müşteri
                            </span>
                            <span t-if="partner.supplier_rank > 0" class="badge bg-warning-subtle text-warning">
                                <i class="fa fa-truck me-1"/>Tedarikçi
                            </span>
                            <span t-if="partner.company_type == 'company'" class="badge bg-light text-muted">
                                <i class="fa fa-building me-1"/>Şirket
                            </span>
                            <span t-if="partner.company_type == 'person'" class="badge bg-light text-muted">
                                <i class="fa fa-user-o me-1"/>Bireysel
                            </span>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a t-attf-href="/mobilsoft/cariler/#{partner.id}/ekstre" class="btn btn-sm btn-outline-secondary">
                            <i class="fa fa-list-alt me-1"/>Ekstre
                        </a>
                        <a t-attf-href="/mobilsoft/cariler/#{partner.id}/mutabakat" class="btn btn-sm btn-outline-primary">
                            <i class="fa fa-handshake-o me-1"/>Mutabakat
                        </a>
                        <a t-attf-href="/mobilsoft/cariler/#{partner.id}/duzenle" class="btn btn-sm ms-btn-brand">
                            <i class="fa fa-pencil me-1"/>Düzenle
                        </a>
                    </div>
                </div>

                <!-- Bakiye Kartları -->
                <div class="row g-3 mb-4">
                    <div class="col-4">
                        <div class="card border-0 shadow-sm ms-kpi-card ms-kpi-card--success">
                            <div class="card-body py-3 text-center">
                                <div class="text-muted small mb-1">Alacak</div>
                                <div class="fw-bold fs-5 text-success">
                                    ₺ <t t-esc="'{:,.2f}'.format(receivable)"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="card border-0 shadow-sm ms-kpi-card ms-kpi-card--danger">
                            <div class="card-body py-3 text-center">
                                <div class="text-muted small mb-1">Borç</div>
                                <div class="fw-bold fs-5 text-danger">
                                    ₺ <t t-esc="'{:,.2f}'.format(payable)"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="card border-0 shadow-sm ms-kpi-card ms-kpi-card--teal">
                            <div class="card-body py-3 text-center">
                                <div class="text-muted small mb-1">Net Bakiye</div>
                                <div t-attf-class="fw-bold fs-5 #{('text-success' if net_balance >= 0 else 'text-danger')}">
                                    ₺ <t t-esc="'{:,.2f}'.format(net_balance)"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3">
                    <!-- İletişim Bilgileri -->
                    <div class="col-md-5">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold"><i class="fa fa-address-card-o me-2 text-muted"/>İletişim</h6>
                            </div>
                            <div class="card-body">
                                <table class="table table-borderless table-sm mb-0">
                                    <tbody>
                                        <tr t-if="partner.vat">
                                            <td class="text-muted" style="width:100px;">VKN/TCKN</td>
                                            <td class="fw-semibold"><t t-esc="partner.vat"/></td>
                                        </tr>
                                        <tr t-if="partner.email">
                                            <td class="text-muted">E-posta</td>
                                            <td><a t-attf-href="mailto:#{partner.email}" class="ms-link"><t t-esc="partner.email"/></a></td>
                                        </tr>
                                        <tr t-if="partner.phone">
                                            <td class="text-muted">Telefon</td>
                                            <td><t t-esc="partner.phone"/></td>
                                        </tr>
                                        <tr t-if="partner.street or partner.city">
                                            <td class="text-muted">Adres</td>
                                            <td>
                                                <t t-if="partner.street"><t t-esc="partner.street"/><br/></t>
                                                <t t-if="partner.city"><t t-esc="partner.city"/></t>
                                                <t t-if="partner.state_id"> / <t t-esc="partner.state_id.name"/></t>
                                                <t t-if="partner.zip"><br/><t t-esc="partner.zip"/></t>
                                                <t t-if="partner.country_id"><br/><t t-esc="partner.country_id.name"/></t>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <t t-if="not partner.vat and not partner.email and not partner.phone">
                                    <div class="text-muted text-center py-3">
                                        <i class="fa fa-info-circle me-1"/>İletişim bilgisi eklenmemiş
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- Son Faturalar -->
                    <div class="col-md-7">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold"><i class="fa fa-file-text-o me-2 text-muted"/>Son Faturalar</h6>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="invoices">
                                    <table class="table table-hover table-sm mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Numara</th>
                                                <th>Tarih</th>
                                                <th>Tür</th>
                                                <th class="text-end">Tutar</th>
                                                <th>Durum</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="invoices" t-as="inv" t-key="inv.id">
                                                <tr>
                                                    <td class="fw-semibold small"><t t-esc="inv.name"/></td>
                                                    <td class="small text-muted"><t t-esc="inv.invoice_date"/></td>
                                                    <td>
                                                        <span t-if="inv.move_type == 'out_invoice'" class="badge bg-success-subtle text-success">Satış</span>
                                                        <span t-if="inv.move_type == 'in_invoice'" class="badge bg-warning-subtle text-warning">Alış</span>
                                                        <span t-if="inv.move_type == 'out_refund'" class="badge bg-danger-subtle text-danger">İade (S)</span>
                                                        <span t-if="inv.move_type == 'in_refund'" class="badge bg-info-subtle text-info">İade (A)</span>
                                                    </td>
                                                    <td class="text-end fw-semibold small">
                                                        ₺ <t t-esc="'{:,.2f}'.format(inv.amount_total)"/>
                                                    </td>
                                                    <td>
                                                        <span t-if="inv.payment_state == 'paid'" class="badge bg-success">Ödendi</span>
                                                        <span t-if="inv.payment_state == 'partial'" class="badge bg-warning">Kısmi</span>
                                                        <span t-if="inv.payment_state == 'not_paid'" class="badge bg-danger">Ödenmedi</span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <div class="text-muted text-center py-4">
                                        <i class="fa fa-inbox fa-2x d-block mb-2"/>
                                        Henüz fatura yok
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
