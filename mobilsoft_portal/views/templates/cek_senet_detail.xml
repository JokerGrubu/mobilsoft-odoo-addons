<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="cek_senet_detail" name="MobilSoft Çek/Senet Detay">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'cek_senet'"/>

            <div class="p-3 p-md-4">
                <a href="/mobilsoft/cek-senet" class="text-muted small text-decoration-none">
                    <i class="fa fa-arrow-left me-1"/>Çek / Senet
                </a>
                <h4 class="fw-bold mt-1 mb-0"><t t-esc="rec.name"/></h4>
                <div class="d-flex gap-2 mt-1 mb-4">
                    <span class="badge bg-light text-dark"><t t-esc="doc_type_map.get(rec.type, '')"/></span>
                    <span class="badge bg-light text-dark"><t t-esc="direction_map.get(rec.direction, '')"/></span>
                    <span t-attf-class="badge #{state_badge.get(rec.state, 'bg-secondary')}">
                        <t t-esc="state_map.get(rec.state, rec.state)"/>
                    </span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold"><i class="fa fa-info-circle me-2 text-muted"/>Bilgiler</h6>
                            </div>
                            <div class="card-body">
                                <table class="table table-borderless table-sm mb-0">
                                    <tbody>
                                        <tr>
                                            <td class="text-muted" style="width:120px;">Cari</td>
                                            <td class="fw-semibold">
                                                <a t-if="rec.partner_id" t-attf-href="/mobilsoft/cariler/#{rec.partner_id.id}" class="ms-link">
                                                    <t t-esc="rec.partner_id.name"/>
                                                </a>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Vade Tarihi</td>
                                            <td><t t-esc="rec.maturity_date or '-'"/></td>
                                        </tr>
                                        <tr t-if="rec.bank_id">
                                            <td class="text-muted">Banka</td>
                                            <td><t t-esc="rec.bank_id.name"/></td>
                                        </tr>
                                        <tr t-if="rec.bank_branch">
                                            <td class="text-muted">Şube</td>
                                            <td><t t-esc="rec.bank_branch"/></td>
                                        </tr>
                                        <tr t-if="rec.account_number">
                                            <td class="text-muted">Hesap No</td>
                                            <td><t t-esc="rec.account_number"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm ms-kpi-card ms-kpi-card--teal">
                            <div class="card-body py-4 text-center">
                                <div class="text-muted small">Tutar</div>
                                <div class="fw-bold fs-2 text-primary">₺ <t t-esc="'{:,.2f}'.format(rec.amount)"/></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
