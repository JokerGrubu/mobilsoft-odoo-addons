<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="dashboard_page" name="MobilSoft Dashboard">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'dashboard'"/>

            <div class="container-fluid">
                <!-- Header Section -->
                <div class="row mb-5">
                    <div class="col-12">
                        <div class="ms-card d-flex justify-content-between align-items-center py-4 px-5">
                            <div>
                                <h2 class="fw-bold mb-1">Hoş Geldiniz, <t t-esc="request.env.user.name"/></h2>
                                <p class="text-muted mb-0">İşletmenizin bugünkü durumuna göz atın.</p>
                            </div>
                            <div class="d-flex gap-3">
                                <button class="btn ms-btn-brand px-4 py-2">
                                    <i class="fa fa-plus me-2"/>Yeni Fatura
                                </button>
                                <button class="btn btn-light border px-4 py-2">
                                    <i class="fa fa-download me-2"/>Rapor Al
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- KPI Stats -->
                <div class="row g-4 mb-5">
                    <div class="col-md-3">
                        <div class="ms-card ms-kpi-card">
                            <div class="ms-kpi-icon bg-primary-light text-primary">
                                <i class="fa fa-turkish-lira"/>
                            </div>
                            <div>
                                <div class="ms-kpi-label">Günlük Satış</div>
                                <div class="ms-kpi-value">₺ <t t-esc="'{:,.2f}'.format(stats['today_sales'])"/></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="ms-card ms-kpi-card">
                            <div class="ms-kpi-icon bg-warning-light text-warning">
                                <i class="fa fa-clock-o"/>
                            </div>
                            <div>
                                <div class="ms-kpi-label">Bekleyen Faturalar</div>
                                <div class="ms-kpi-value"><t t-esc="stats['pending_invoices']"/> Adet</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="ms-card ms-kpi-card">
                            <div class="ms-kpi-icon bg-danger-light text-danger">
                                <i class="fa fa-exclamation-triangle"/>
                            </div>
                            <div>
                                <div class="ms-kpi-label">Kritik Stok</div>
                                <div class="ms-kpi-value"><t t-esc="stats['stock_alerts']"/> Ürün</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="ms-card ms-kpi-card">
                            <div class="ms-kpi-icon bg-teal-light text-teal">
                                <i class="fa fa-shopping-bag"/>
                            </div>
                            <div>
                                <div class="ms-kpi-label">Pazaryeri Sipariş</div>
                                <div class="ms-kpi-value"><t t-esc="stats['ct_products']"/> Yeni</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Features Grid -->
                <div class="row">
                    <div class="col-lg-8">
                        <div class="ms-card h-100">
                            <h4 class="fw-bold mb-4">Hızlı İşlemler</h4>
                            <div class="row g-3">
                                <t t-foreach="[
                                    {'url': '/mobilsoft/cariler', 'icon': 'fa-users', 'title': 'Cari Yönetimi', 'desc': 'Müşteri ve tedarikçi takibi'},
                                    {'url': '/mobilsoft/urunler', 'icon': 'fa-cube', 'title': 'Stok Kontrol', 'desc': 'Ürün ve depo yönetimi'},
                                    {'url': '/mobilsoft/faturalar', 'icon': 'fa-file-text-o', 'title': 'E-Fatura', 'desc': 'Fatura ve e-arşiv işlemleri'},
                                    {'url': '/mobilsoft/hesaplar', 'icon': 'fa-university', 'title': 'Kasa &amp; Banka', 'desc': 'Nakit akışı takibi'},
                                ]" t-as="feature" t-key="feature['url']">
                                    <div class="col-md-6">
                                        <a t-att-href="feature['url']" class="text-decoration-none">
                                            <div class="p-4 border rounded-4 hover-bg-light transition-all">
                                                <i t-attf-class="fa #{feature['icon']} fs-3 mb-3 text-primary"/>
                                                <h5 class="fw-bold text-dark mb-1"><t t-esc="feature['title']"/></h5>
                                                <p class="text-muted small mb-0"><t t-esc="feature['desc']"/></p>
                                            </div>
                                        </a>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="ms-card bg-primary text-white h-100">
                            <h4 class="fw-bold mb-4">Duyurular</h4>
                            <div class="d-flex flex-column gap-4">
                                <div>
                                    <span class="badge bg-white text-primary mb-2">Yeni Özellik</span>
                                    <h6 class="fw-bold mb-1">Banka Senkronizasyonu</h6>
                                    <p class="small opacity-75">Artık tüm banka hareketleriniz otomatik olarak sisteme düşüyor.</p>
                                </div>
                                <div class="border-top pt-3 border-white border-opacity-25">
                                    <span class="badge bg-white text-primary mb-2">Duyuru</span>
                                    <h6 class="fw-bold mb-1">KVKK Güncellemesi</h6>
                                    <p class="small opacity-75">Veri güvenliği politikalarımız güncellendi. Lütfen inceleyin.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
