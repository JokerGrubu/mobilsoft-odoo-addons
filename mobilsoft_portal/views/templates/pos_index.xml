<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="pos_index" name="MobilSoft POS">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'pos'"/>

            <div class="p-3 p-md-4">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <h4 class="mb-0 fw-bold"><i class="fa fa-desktop me-2 text-muted"/>Kasa (POS)</h4>
                    <a href="/mobilsoft/export/pos-siparisler" class="btn btn-sm btn-outline-success">
                        <i class="fa fa-file-excel-o me-1"/>Excel
                    </a>
                </div>
                <small class="text-muted d-block mb-4">Satış noktası yönetimi</small>

                <!-- KPI Kartları -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body py-3 text-center">
                                <div class="text-muted small">Toplam Sipariş</div>
                                <div class="fs-4 fw-bold text-primary"><t t-esc="total_orders"/></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body py-3 text-center">
                                <div class="text-muted small">Bugün Sipariş</div>
                                <div class="fs-4 fw-bold text-success"><t t-esc="today_count"/></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body py-3 text-center">
                                <div class="text-muted small">Bugün Ciro</div>
                                <div class="fs-5 fw-bold text-info">
                                    <t t-esc="currency.symbol"/> <t t-esc="'{:,.2f}'.format(today_revenue)"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body py-3 text-center">
                                <div class="text-muted small">Kasalar</div>
                                <div class="fs-4 fw-bold text-warning"><t t-esc="len(configs)"/></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Mesajlar -->
                <t t-set="url_success" t-value="request.params.get('success', '')"/>
                <t t-set="url_error" t-value="request.params.get('error', '')"/>
                <t t-if="url_success">
                    <div class="alert alert-success d-flex align-items-center py-2 small mb-3"><i class="fa fa-check-circle me-2"/><t t-esc="url_success"/></div>
                </t>
                <t t-if="url_error">
                    <div class="alert alert-danger d-flex align-items-center py-2 small mb-3"><i class="fa fa-exclamation-circle me-2"/><t t-esc="url_error"/></div>
                </t>

                <div class="row g-4">
                    <!-- Sol: Kasalar + Oturumlar -->
                    <div class="col-lg-5">
                        <!-- Kasa Yapılandırmaları + Oturum Aç -->
                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                                <h6 class="mb-0 fw-bold"><i class="fa fa-calculator me-2 text-primary"/>Kasalar</h6>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="configs">
                                    <t t-foreach="configs" t-as="cfg" t-key="cfg.id">
                                        <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom">
                                            <div>
                                                <div class="fw-semibold small"><t t-esc="cfg.name"/></div>
                                            </div>
                                            <form action="/mobilsoft/pos/oturum-ac" method="post" class="d-inline">
                                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                <input type="hidden" name="config_id" t-att-value="cfg.id"/>
                                                <button type="submit" class="btn btn-sm btn-outline-success" title="Oturum Aç">
                                                    <i class="fa fa-play me-1"/>Oturum Aç
                                                </button>
                                            </form>
                                        </div>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="p-3 text-muted small text-center">Kasa tanımı yok</div>
                                </t>
                            </div>
                        </div>

                        <!-- Açık Oturumlar -->
                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold"><i class="fa fa-play-circle me-2 text-success"/>Açık Oturumlar</h6>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="open_sessions">
                                    <t t-foreach="open_sessions" t-as="sess" t-key="sess.id">
                                        <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom">
                                            <div>
                                                <div class="fw-semibold small"><t t-esc="sess.name"/></div>
                                                <div class="text-muted" style="font-size:11px;">
                                                    <t t-esc="sess.config_id.name"/> — <t t-esc="sess.user_id.name"/>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge bg-success">Açık</span>
                                                <form t-attf-action="/mobilsoft/pos/oturum-kapat/#{sess.id}" method="post" class="d-inline">
                                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Oturumu Kapat"
                                                            onclick="return confirm('Bu oturumu kapatmak istediğinize emin misiniz?')">
                                                        <i class="fa fa-stop me-1"/>Kapat
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="p-3 text-muted small text-center">Açık oturum yok</div>
                                </t>
                            </div>
                        </div>

                        <!-- Son Kapalı Oturumlar -->
                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold"><i class="fa fa-history me-2 text-secondary"/>Son Oturumlar</h6>
                            </div>
                            <div class="card-body p-0" style="max-height:300px; overflow-y:auto;">
                                <t t-if="closed_sessions">
                                    <t t-foreach="closed_sessions" t-as="sess" t-key="sess.id">
                                        <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom">
                                            <div>
                                                <div class="fw-semibold small"><t t-esc="sess.name"/></div>
                                                <div class="text-muted" style="font-size:11px;">
                                                    <t t-esc="sess.config_id.name"/>
                                                </div>
                                            </div>
                                            <div class="text-end">
                                                <span class="badge bg-secondary-subtle text-secondary">Kapalı</span>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="p-3 text-muted small text-center">Oturum geçmişi yok</div>
                                </t>
                            </div>
                        </div>

                        <!-- Ödeme Yöntemleri -->
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold"><i class="fa fa-credit-card me-2 text-info"/>Ödeme Yöntemleri</h6>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="payment_methods">
                                    <t t-foreach="payment_methods" t-as="pm" t-key="pm.id">
                                        <div class="d-flex align-items-center px-3 py-2 border-bottom">
                                            <i class="fa fa-check-circle text-success me-2"/>
                                            <span class="small"><t t-esc="pm.name"/></span>
                                        </div>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="p-3 text-muted small text-center">Ödeme yöntemi yok</div>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- Sağ: Son Siparişler -->
                    <div class="col-lg-7">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold"><i class="fa fa-list me-2 text-primary"/>Son POS Siparişleri</h6>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="orders">
                                    <div class="table-responsive" style="max-height:600px; overflow-y:auto;">
                                        <table class="table table-sm table-hover mb-0">
                                            <thead class="table-light sticky-top">
                                                <tr>
                                                    <th class="small">Sipariş</th>
                                                    <th class="small">Tarih</th>
                                                    <th class="small">Müşteri</th>
                                                    <th class="small text-end">Tutar</th>
                                                    <th class="small text-center">Durum</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="orders" t-as="o" t-key="o.id">
                                                    <tr class="cursor-pointer" t-attf-onclick="window.location='/mobilsoft/pos/siparis/#{o.id}'">
                                                        <td class="small fw-semibold text-primary"><t t-esc="o.name"/></td>
                                                        <td class="small text-muted"><t t-esc="o.date_order.strftime('%d.%m.%Y %H:%M') if o.date_order else '-'"/></td>
                                                        <td class="small"><t t-esc="o.partner_id.name or 'Misafir'"/></td>
                                                        <td class="small text-end fw-semibold">
                                                            <t t-esc="currency.symbol"/> <t t-esc="'{:,.2f}'.format(o.amount_total)"/>
                                                        </td>
                                                        <td class="small text-center">
                                                            <t t-if="o.state == 'paid'">
                                                                <span class="badge bg-success-subtle text-success">Ödendi</span>
                                                            </t>
                                                            <t t-elif="o.state == 'done'">
                                                                <span class="badge bg-primary-subtle text-primary">Tamamlandı</span>
                                                            </t>
                                                            <t t-elif="o.state == 'invoiced'">
                                                                <span class="badge bg-info-subtle text-info">Faturalandı</span>
                                                            </t>
                                                            <t t-elif="o.state == 'cancel'">
                                                                <span class="badge bg-danger-subtle text-danger">İptal</span>
                                                            </t>
                                                            <t t-else="">
                                                                <span class="badge bg-secondary-subtle text-secondary"><t t-esc="o.state"/></span>
                                                            </t>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="p-4 text-center text-muted">
                                        <i class="fa fa-desktop fa-3x mb-3 d-block"/>
                                        <p>Henüz POS siparişi yok.</p>
                                        <small>POS oturumu açarak satış yapmaya başlayabilirsiniz.</small>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- POS Sipariş Detay -->
    <template id="pos_order_detail" name="POS Sipariş Detay">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'pos'"/>

            <div class="p-3 p-md-4">
                <a href="/mobilsoft/pos" class="text-muted small text-decoration-none">
                    <i class="fa fa-arrow-left me-1"/>POS
                </a>
                <h4 class="fw-bold mt-1 mb-4">
                    <i class="fa fa-file-text me-2 text-muted"/>
                    <t t-esc="order.name"/>
                </h4>

                <div class="row g-4">
                    <div class="col-md-8">
                        <!-- Kalemler -->
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold">Kalemler</h6>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-sm mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="small">Ürün</th>
                                            <th class="small text-center">Miktar</th>
                                            <th class="small text-end">Birim Fiyat</th>
                                            <th class="small text-end">Toplam</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="order.lines" t-as="line" t-key="line.id">
                                            <tr>
                                                <td class="small"><t t-esc="line.full_product_name or line.product_id.name"/></td>
                                                <td class="small text-center"><t t-esc="line.qty"/></td>
                                                <td class="small text-end"><t t-esc="'{:,.2f}'.format(line.price_unit)"/></td>
                                                <td class="small text-end fw-semibold"><t t-esc="'{:,.2f}'.format(line.price_subtotal_incl)"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                    <tfoot class="table-light">
                                        <tr>
                                            <td colspan="3" class="text-end fw-bold small">Toplam</td>
                                            <td class="text-end fw-bold">
                                                <t t-esc="currency.symbol"/> <t t-esc="'{:,.2f}'.format(order.amount_total)"/>
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <!-- Bilgiler -->
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold">Bilgiler</h6>
                            </div>
                            <div class="card-body">
                                <table class="table table-sm table-borderless mb-0">
                                    <tr>
                                        <td class="text-muted small">Tarih</td>
                                        <td class="small fw-semibold"><t t-esc="order.date_order"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted small">Müşteri</td>
                                        <td class="small"><t t-esc="order.partner_id.name or 'Misafir'"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted small">Oturum</td>
                                        <td class="small"><t t-esc="order.session_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted small">Kasa</td>
                                        <td class="small"><t t-esc="order.config_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted small">Kasiyer</td>
                                        <td class="small"><t t-esc="order.user_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted small">Durum</td>
                                        <td>
                                            <t t-if="order.state == 'paid'">
                                                <span class="badge bg-success">Ödendi</span>
                                            </t>
                                            <t t-elif="order.state == 'done'">
                                                <span class="badge bg-primary">Tamamlandı</span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge bg-secondary"><t t-esc="order.state"/></span>
                                            </t>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Ödemeler -->
                        <div class="card border-0 shadow-sm mt-3">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold">Ödemeler</h6>
                            </div>
                            <div class="card-body p-0">
                                <t t-foreach="order.payment_ids" t-as="pay" t-key="pay.id">
                                    <div class="d-flex justify-content-between px-3 py-2 border-bottom">
                                        <span class="small"><t t-esc="pay.payment_method_id.name"/></span>
                                        <span class="small fw-semibold">
                                            <t t-esc="currency.symbol"/> <t t-esc="'{:,.2f}'.format(pay.amount)"/>
                                        </span>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
