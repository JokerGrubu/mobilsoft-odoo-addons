<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="kullanicilar_list" name="MobilSoft Kullanıcılar">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'ayarlar'"/>

            <div class="p-3 p-md-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="mb-1 fw-bold"><i class="fa fa-users me-2 text-muted"/>Kullanıcı Yönetimi</h4>
                        <small class="text-muted"><t t-esc="len(users)"/> kullanıcı</small>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/mobilsoft/ayarlar/roller" class="btn btn-outline-secondary btn-sm">
                            <i class="fa fa-shield me-1"/>Roller
                        </a>
                        <a href="/mobilsoft/ayarlar/kullanicilar/yeni" class="btn btn-primary btn-sm">
                            <i class="fa fa-plus me-1"/>Yeni Kullanıcı
                        </a>
                    </div>
                </div>

                <t t-if="success">
                    <div class="alert alert-success alert-dismissible fade show">
                        <i class="fa fa-check-circle me-2"/><t t-esc="success"/>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"/>
                    </div>
                </t>
                <t t-if="error">
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="fa fa-exclamation-triangle me-2"/><t t-esc="error"/>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"/>
                    </div>
                </t>

                <div class="table-responsive">
                    <table class="table table-hover align-middle bg-white shadow-sm rounded">
                        <thead class="table-light">
                            <tr>
                                <th>Ad</th>
                                <th>E-posta / Login</th>
                                <th>Telefon</th>
                                <th>Durum</th>
                                <th class="text-end">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="users" t-as="u" t-key="u.id">
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="ms-avatar" style="width:32px;height:32px;font-size:14px;">
                                                <t t-esc="(u.name or '?')[0].upper()"/>
                                            </div>
                                            <span class="fw-bold"><t t-esc="u.name"/></span>
                                        </div>
                                    </td>
                                    <td class="text-muted small"><t t-esc="u.login"/></td>
                                    <td class="text-muted small"><t t-esc="u.partner_id.phone or '-'"/></td>
                                    <td>
                                        <span t-if="u.active" class="badge bg-success-subtle text-success">Aktif</span>
                                        <span t-else="" class="badge bg-danger-subtle text-danger">Pasif</span>
                                    </td>
                                    <td class="text-end">
                                        <a t-attf-href="/mobilsoft/ayarlar/kullanicilar/#{u.id}/duzenle" class="btn btn-sm btn-outline-primary me-1">
                                            <i class="fa fa-pencil"/>
                                        </a>
                                        <form t-attf-action="/mobilsoft/ayarlar/kullanicilar/#{u.id}/sil" method="post" class="d-inline">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bu kullanıcıyı devre dışı bırakmak istediğinize emin misiniz?')">
                                                <i class="fa fa-ban"/>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            </t>
                            <t t-if="not users">
                                <tr><td colspan="5" class="text-center text-muted py-4">Henüz kullanıcı yok</td></tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
        </t>
    </template>

</odoo>
