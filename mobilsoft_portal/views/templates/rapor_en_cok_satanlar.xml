<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="rapor_en_cok_satanlar" name="MobilSoft En Çok Satanlar">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'raporlar'"/>

            <div class="p-3 p-md-4">
                <a href="/mobilsoft/raporlar" class="text-muted small text-decoration-none">
                    <i class="fa fa-arrow-left me-1"/>Raporlar
                </a>
                <h4 class="fw-bold mt-1 mb-4"><i class="fa fa-trophy me-2 text-muted"/>En Çok Satanlar</h4>

                <!-- Tarih -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body py-3">
                        <form method="get" action="/mobilsoft/raporlar/en-cok-satanlar" class="row g-2 align-items-end">
                            <div class="col-auto">
                                <label class="form-label small fw-semibold mb-1">Başlangıç</label>
                                <input type="date" name="start" class="form-control form-control-sm" t-att-value="start_date"/>
                            </div>
                            <div class="col-auto">
                                <label class="form-label small fw-semibold mb-1">Bitiş</label>
                                <input type="date" name="end" class="form-control form-control-sm" t-att-value="end_date"/>
                            </div>
                            <div class="col-auto">
                                <button type="submit" class="btn btn-sm ms-btn-brand"><i class="fa fa-filter me-1"/>Filtrele</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="row g-3">
                    <!-- En Çok Satan Ürünler -->
                    <div class="col-md-7">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold"><i class="fa fa-cube me-2 text-muted"/>En Çok Satan Ürünler</h6>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="top_products">
                                    <table class="table table-sm mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>#</th>
                                                <th>Ürün</th>
                                                <th class="text-end">Adet</th>
                                                <th class="text-end">Ciro</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="top_products" t-as="p" t-key="p_index">
                                                <tr>
                                                    <td>
                                                        <span t-if="p_index == 0" class="badge bg-warning text-dark">🥇</span>
                                                        <span t-elif="p_index == 1" class="badge bg-secondary">🥈</span>
                                                        <span t-elif="p_index == 2" class="badge bg-danger-subtle text-danger">🥉</span>
                                                        <span t-else="" class="text-muted small"><t t-esc="p_index + 1"/></span>
                                                    </td>
                                                    <td>
                                                        <div class="small fw-semibold"><t t-esc="p['name']"/></div>
                                                        <div t-if="p['code']" class="text-muted" style="font-size:11px;"><t t-esc="p['code']"/></div>
                                                    </td>
                                                    <td class="text-end small"><t t-esc="'{:,.0f}'.format(p['qty'])"/></td>
                                                    <td class="text-end small fw-bold text-success">₺ <t t-esc="'{:,.2f}'.format(p['total'])"/></td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <div class="text-muted text-center py-4"><i class="fa fa-inbox fa-2x d-block mb-2"/>Veri yok</div>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- En İyi Müşteriler -->
                    <div class="col-md-5">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold"><i class="fa fa-star me-2 text-muted"/>En İyi Müşteriler</h6>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="top_customers">
                                    <table class="table table-sm mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>#</th>
                                                <th>Müşteri</th>
                                                <th class="text-end">Sipariş</th>
                                                <th class="text-end">Toplam</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="top_customers" t-as="c" t-key="c_index">
                                                <tr>
                                                    <td class="text-muted small"><t t-esc="c_index + 1"/></td>
                                                    <td class="small fw-semibold"><t t-esc="c['name']"/></td>
                                                    <td class="text-end small"><t t-esc="c['count']"/></td>
                                                    <td class="text-end small fw-bold text-primary">₺ <t t-esc="'{:,.2f}'.format(c['total'])"/></td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <div class="text-muted text-center py-4"><i class="fa fa-inbox fa-2x d-block mb-2"/>Veri yok</div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
