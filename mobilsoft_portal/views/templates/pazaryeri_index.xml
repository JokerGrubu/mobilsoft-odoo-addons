<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="pazaryeri_index" name="MobilSoft CepteTedarik Pazaryeri">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'pazaryeri'"/>

            <div class="p-3 p-md-4">
                <h4 class="mb-1 fw-bold"><i class="fa fa-shopping-bag me-2 text-muted"/>CepteTedarik</h4>
                <small class="text-muted d-block mb-4">Pazaryeri entegrasyonları ve sipariş yönetimi</small>

                <!-- KPI Kartları -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body py-3 text-center">
                                <div class="text-muted small">Kanallar</div>
                                <div class="fs-4 fw-bold text-primary"><t t-esc="stats['channel_count']"/></div>
                                <div class="text-muted" style="font-size:11px;"><t t-esc="stats['active_channels']"/> aktif</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body py-3 text-center">
                                <div class="text-muted small">Ürünler</div>
                                <div class="fs-4 fw-bold text-success"><t t-esc="stats['product_count']"/></div>
                                <div class="text-muted" style="font-size:11px;"><t t-esc="stats['synced_products']"/> senkron</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body py-3 text-center">
                                <div class="text-muted small">Siparişler</div>
                                <div class="fs-4 fw-bold text-info"><t t-esc="stats['order_count']"/></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body py-3 text-center">
                                <div class="text-muted small">Bekleyen</div>
                                <div class="fs-4 fw-bold text-warning"><t t-esc="stats['pending_orders']"/></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tabs -->
                <ul class="nav nav-tabs mb-3">
                    <li class="nav-item">
                        <a t-attf-class="nav-link #{'active' if tab == 'kanallar' else ''}" href="/mobilsoft/pazaryeri?tab=kanallar">
                            <i class="fa fa-plug me-1"/>Kanallar
                        </a>
                    </li>
                    <li class="nav-item">
                        <a t-attf-class="nav-link #{'active' if tab == 'urunler' else ''}" href="/mobilsoft/pazaryeri?tab=urunler">
                            <i class="fa fa-cube me-1"/>Ürünler
                        </a>
                    </li>
                    <li class="nav-item">
                        <a t-attf-class="nav-link #{'active' if tab == 'siparisler' else ''}" href="/mobilsoft/pazaryeri?tab=siparisler">
                            <i class="fa fa-shopping-cart me-1"/>Siparişler
                        </a>
                    </li>
                    <li class="nav-item">
                        <a t-attf-class="nav-link #{'active' if tab == 'loglar' else ''}" href="/mobilsoft/pazaryeri?tab=loglar">
                            <i class="fa fa-history me-1"/>Senkronizasyon Logları
                        </a>
                    </li>
                </ul>

                <!-- TAB: Kanallar -->
                <t t-if="tab == 'kanallar'">
                    <div class="mb-3 text-end">
                        <a href="/mobilsoft/pazaryeri/kanal/yeni" class="btn ms-btn-brand btn-sm">
                            <i class="fa fa-plus me-1"/>Yeni Kanal Ekle
                        </a>
                    </div>
                    <div class="row g-3">
                        <t t-if="channels">
                            <t t-foreach="channels" t-as="ch" t-key="ch.id">
                                <div class="col-md-4">
                                    <a t-attf-href="/mobilsoft/pazaryeri/kanal/#{ch.id}" class="text-decoration-none">
                                        <div class="card border-0 shadow-sm h-100 ms-product-card">
                                            <div class="card-body py-4">
                                                <div class="d-flex align-items-center mb-3">
                                                    <div class="ms-quick-icon bg-primary-subtle text-primary me-3">
                                                        <t t-if="ch.channel_type == 'trendyol'"><i class="fa fa-shopping-bag"/></t>
                                                        <t t-elif="ch.channel_type == 'hepsiburada'"><i class="fa fa-shopping-cart"/></t>
                                                        <t t-elif="ch.channel_type == 'n11'"><i class="fa fa-globe"/></t>
                                                        <t t-elif="ch.channel_type == 'ciceksepeti'"><i class="fa fa-gift"/></t>
                                                        <t t-else=""><i class="fa fa-plug"/></t>
                                                    </div>
                                                    <div>
                                                        <h6 class="fw-bold text-dark mb-0"><t t-esc="ch.name"/></h6>
                                                        <small class="text-muted text-capitalize"><t t-esc="ch.channel_type or '-'"/></small>
                                                    </div>
                                                </div>
                                                <div class="d-flex justify-content-between text-muted small">
                                                    <span>
                                                        <t t-if="ch.active">
                                                            <span class="badge bg-success-subtle text-success">Aktif</span>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="badge bg-secondary-subtle text-secondary">Pasif</span>
                                                        </t>
                                                    </span>
                                                    <span>
                                                        Son senkron: <t t-esc="ch.last_sync.strftime('%d.%m %H:%M') if ch.last_sync else 'Yok'"/>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            </t>
                        </t>
                        <t t-else="">
                            <div class="col-12">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body py-5 text-center text-muted">
                                        <i class="fa fa-plug fa-3x mb-3 d-block"/>
                                        <p>Henüz pazaryeri kanalı eklenmedi.</p>
                                        <a href="/mobilsoft/pazaryeri/kanal/yeni" class="btn ms-btn-brand mt-2">
                                            <i class="fa fa-plus me-1"/>Yeni Kanal Ekle
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>

                <!-- TAB: Ürünler -->
                <t t-if="tab == 'urunler'">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-0">
                            <t t-if="mp_products">
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="small">Ürün</th>
                                                <th class="small">Kanal</th>
                                                <th class="small">Kanal SKU</th>
                                                <th class="small text-end">Fiyat</th>
                                                <th class="small text-center">Stok</th>
                                                <th class="small text-center">Durum</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="mp_products" t-as="mp" t-key="mp.id">
                                                <tr>
                                                    <td class="small fw-semibold"><t t-esc="mp.title or (mp.product_id.name if mp.product_id else '-')"/></td>
                                                    <td class="small text-muted"><t t-esc="mp.channel_id.name"/></td>
                                                    <td class="small"><t t-esc="mp.channel_sku or '-'"/></td>
                                                    <td class="small text-end">
                                                        <t t-esc="currency.symbol"/> <t t-esc="'{:,.2f}'.format(mp.sale_price or 0)"/>
                                                    </td>
                                                    <td class="small text-center"><t t-esc="int(mp.qty_available or 0)"/></td>
                                                    <td class="small text-center">
                                                        <t t-if="mp.sync_status == 'synced'">
                                                            <span class="badge bg-success-subtle text-success">Senkron</span>
                                                        </t>
                                                        <t t-elif="mp.sync_status == 'error'">
                                                            <span class="badge bg-danger-subtle text-danger">Hata</span>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="badge bg-warning-subtle text-warning">Bekliyor</span>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="p-4 text-center text-muted">Pazaryeri ürünü yok</div>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- TAB: Siparişler -->
                <t t-if="tab == 'siparisler'">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-0">
                            <t t-if="mp_orders">
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="small">Sipariş No</th>
                                                <th class="small">Kanal</th>
                                                <th class="small">Müşteri</th>
                                                <th class="small">Tarih</th>
                                                <th class="small text-end">Tutar</th>
                                                <th class="small text-center">Durum</th>
                                                <th class="small text-center">Odoo</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="mp_orders" t-as="mo" t-key="mo.id">
                                                <tr>
                                                    <td class="small fw-semibold"><t t-esc="mo.channel_order_id or '-'"/></td>
                                                    <td class="small text-muted"><t t-esc="mo.channel_id.name"/></td>
                                                    <td class="small"><t t-esc="mo.partner_name or '-'"/></td>
                                                    <td class="small"><t t-esc="mo.order_date.strftime('%d.%m.%Y') if mo.order_date else '-'"/></td>
                                                    <td class="small text-end fw-semibold">
                                                        <t t-esc="currency.symbol"/> <t t-esc="'{:,.2f}'.format(mo.amount_total or 0)"/>
                                                    </td>
                                                    <td class="small text-center">
                                                        <t t-if="mo.status == 'new'">
                                                            <span class="badge bg-info-subtle text-info">Yeni</span>
                                                        </t>
                                                        <t t-elif="mo.status == 'processing'">
                                                            <span class="badge bg-warning-subtle text-warning">İşleniyor</span>
                                                        </t>
                                                        <t t-elif="mo.status == 'shipped'">
                                                            <span class="badge bg-primary-subtle text-primary">Kargoda</span>
                                                        </t>
                                                        <t t-elif="mo.status == 'delivered'">
                                                            <span class="badge bg-success-subtle text-success">Teslim</span>
                                                        </t>
                                                        <t t-elif="mo.status == 'cancelled'">
                                                            <span class="badge bg-danger-subtle text-danger">İptal</span>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="badge bg-secondary-subtle text-secondary"><t t-esc="mo.status or '-'"/></span>
                                                        </t>
                                                    </td>
                                                    <td class="small text-center">
                                                        <t t-if="mo.synced_to_odoo">
                                                            <i class="fa fa-check-circle text-success"/>
                                                        </t>
                                                        <t t-else="">
                                                            <i class="fa fa-clock-o text-warning"/>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="p-4 text-center text-muted">Pazaryeri siparişi yok</div>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- TAB: Loglar -->
                <t t-if="tab == 'loglar'">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-0">
                            <t t-if="sync_logs">
                                <div class="table-responsive" style="max-height:500px; overflow-y:auto;">
                                    <table class="table table-sm table-hover mb-0">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th class="small">Tarih</th>
                                                <th class="small">Kanal</th>
                                                <th class="small">İşlem</th>
                                                <th class="small text-center">Durum</th>
                                                <th class="small">Detay</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="sync_logs" t-as="log" t-key="log.id">
                                                <tr>
                                                    <td class="small text-muted"><t t-esc="log.create_date.strftime('%d.%m.%Y %H:%M') if log.create_date else '-'"/></td>
                                                    <td class="small"><t t-esc="log.channel_id.name"/></td>
                                                    <td class="small"><t t-esc="log.operation or '-'"/></td>
                                                    <td class="small text-center">
                                                        <t t-if="log.status == 'success'">
                                                            <span class="badge bg-success-subtle text-success">Başarılı</span>
                                                        </t>
                                                        <t t-elif="log.status == 'error'">
                                                            <span class="badge bg-danger-subtle text-danger">Hata</span>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="badge bg-secondary-subtle text-secondary"><t t-esc="log.status or '-'"/></span>
                                                        </t>
                                                    </td>
                                                    <td class="small text-muted text-truncate" style="max-width:300px;">
                                                        <t t-esc="log.message or '-'"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="p-4 text-center text-muted">Senkronizasyon logu yok</div>
                            </t>
                        </div>
                    </div>
                </t>

            </div>
        </t>
    </template>

    <!-- Kanal Detay -->
    <template id="pazaryeri_channel_detail" name="Pazaryeri Kanal Detay">
        <t t-call="mobilsoft_portal.portal_layout">
            <t t-set="page_name" t-value="'pazaryeri'"/>

            <div class="p-3 p-md-4">
                <a href="/mobilsoft/pazaryeri" class="text-muted small text-decoration-none">
                    <i class="fa fa-arrow-left me-1"/>CepteTedarik
                </a>
                <h4 class="fw-bold mt-1 mb-4">
                    <i class="fa fa-plug me-2 text-muted"/>
                    <t t-esc="channel.name"/>
                </h4>

                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold">Kanal Bilgileri</h6>
                            </div>
                            <div class="card-body">
                                <table class="table table-sm table-borderless mb-0">
                                    <tr>
                                        <td class="text-muted small">Tür</td>
                                        <td class="small fw-semibold text-capitalize"><t t-esc="channel.channel_type or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted small">Durum</td>
                                        <td>
                                            <t t-if="channel.active">
                                                <span class="badge bg-success">Aktif</span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge bg-secondary">Pasif</span>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted small">Son Senkron</td>
                                        <td class="small"><t t-esc="channel.last_sync or 'Yok'"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted small">Son Durum</td>
                                        <td class="small"><t t-esc="channel.last_sync_status or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted small">Ürün Sayısı</td>
                                        <td class="small fw-semibold"><t t-esc="len(products)"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted small">Sipariş Sayısı</td>
                                        <td class="small fw-semibold"><t t-esc="len(orders)"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Özellikler -->
                        <div class="card border-0 shadow-sm mt-3">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold">Özellikler</h6>
                            </div>
                            <div class="card-body">
                                <div class="d-flex flex-wrap gap-2">
                                    <t t-if="channel.supports_inventory">
                                        <span class="badge bg-success-subtle text-success"><i class="fa fa-check me-1"/>Stok</span>
                                    </t>
                                    <t t-if="channel.supports_orders">
                                        <span class="badge bg-success-subtle text-success"><i class="fa fa-check me-1"/>Sipariş</span>
                                    </t>
                                    <t t-if="channel.supports_pricing">
                                        <span class="badge bg-success-subtle text-success"><i class="fa fa-check me-1"/>Fiyat</span>
                                    </t>
                                    <t t-if="channel.supports_returns">
                                        <span class="badge bg-success-subtle text-success"><i class="fa fa-check me-1"/>İade</span>
                                    </t>
                                    <t t-if="channel.auto_confirm_orders">
                                        <span class="badge bg-info-subtle text-info"><i class="fa fa-bolt me-1"/>Oto Onay</span>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-8">
                        <!-- Ürünler -->
                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold">Ürünler (<t t-esc="len(products)"/>)</h6>
                            </div>
                            <div class="card-body p-0" style="max-height:300px; overflow-y:auto;">
                                <t t-if="products">
                                    <table class="table table-sm table-hover mb-0">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th class="small">Ürün</th>
                                                <th class="small text-end">Fiyat</th>
                                                <th class="small text-center">Stok</th>
                                                <th class="small text-center">Durum</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="products" t-as="p" t-key="p.id">
                                                <tr>
                                                    <td class="small"><t t-esc="p.title or (p.product_id.name if p.product_id else '-')"/></td>
                                                    <td class="small text-end"><t t-esc="'{:,.2f}'.format(p.sale_price or 0)"/></td>
                                                    <td class="small text-center"><t t-esc="int(p.qty_available or 0)"/></td>
                                                    <td class="small text-center">
                                                        <t t-if="p.sync_status == 'synced'">
                                                            <span class="badge bg-success-subtle text-success">OK</span>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="badge bg-warning-subtle text-warning"><t t-esc="p.sync_status or '?'"/></span>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <div class="p-3 text-muted small text-center">Ürün yok</div>
                                </t>
                            </div>
                        </div>

                        <!-- Son Siparişler -->
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white border-bottom py-3">
                                <h6 class="mb-0 fw-bold">Son Siparişler (<t t-esc="len(orders)"/>)</h6>
                            </div>
                            <div class="card-body p-0" style="max-height:300px; overflow-y:auto;">
                                <t t-if="orders">
                                    <table class="table table-sm table-hover mb-0">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th class="small">Sipariş</th>
                                                <th class="small">Müşteri</th>
                                                <th class="small text-end">Tutar</th>
                                                <th class="small text-center">Durum</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="orders" t-as="o" t-key="o.id">
                                                <tr>
                                                    <td class="small"><t t-esc="o.channel_order_id or '-'"/></td>
                                                    <td class="small"><t t-esc="o.partner_name or '-'"/></td>
                                                    <td class="small text-end"><t t-esc="'{:,.2f}'.format(o.amount_total or 0)"/></td>
                                                    <td class="small text-center">
                                                        <span class="badge bg-secondary-subtle text-secondary"><t t-esc="o.status or '-'"/></span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <div class="p-3 text-muted small text-center">Sipariş yok</div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
