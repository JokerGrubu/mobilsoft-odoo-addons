<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cheque_promissory_tree" model="ir.ui.view">
        <field name="name">mobilsoft.cheque.promissory.list</field>
        <field name="model">mobilsoft.cheque.promissory</field>
        <field name="arch" type="xml">
            <list string="Çek/Senet" decoration-danger="is_overdue">
                <field name="name"/>
                <field name="type"/>
                <field name="direction"/>
                <field name="partner_id"/>
                <field name="amount"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="maturity_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'collected' or state == 'paid'"
                       decoration-warning="state == 'endorsed'"
                       decoration-danger="state == 'bounced' or is_overdue"
                       decoration-muted="state == 'cancelled'"/>
                <field name="is_overdue" column_invisible="1"/>
                <field name="days_overdue"/>
            </list>
        </field>
    </record>

    <record id="view_cheque_promissory_form" model="ir.ui.view">
        <field name="name">mobilsoft.cheque.promissory.form</field>
        <field name="model">mobilsoft.cheque.promissory</field>
        <field name="arch" type="xml">
            <form string="Çek/Senet">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="portfolio,collected,paid"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="type"/>
                            <field name="direction"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="currency_id"/>
                            <field name="maturity_date"/>
                            <field name="collection_date"/>
                        </group>
                    </group>
                    <group string="Banka Bilgileri">
                        <field name="bank_id"/>
                        <field name="bank_branch"/>
                        <field name="account_number"/>
                    </group>
                    <field name="notes" placeholder="Notlar..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cheque_promissory_search" model="ir.ui.view">
        <field name="name">mobilsoft.cheque.promissory.search</field>
        <field name="model">mobilsoft.cheque.promissory</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <filter name="overdue" string="Vadesi Geçmiş" domain="[('is_overdue','=',True)]"/>
                <filter name="portfolio" string="Portföyde" domain="[('state','=','portfolio')]"/>
                <separator/>
                <filter name="group_type" string="Tür" context="{'group_by': 'type'}"/>
                <filter name="group_direction" string="Yön" context="{'group_by': 'direction'}"/>
                <filter name="group_state" string="Durum" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_cheque_promissory" model="ir.actions.act_window">
        <field name="name">Çek/Senet</field>
        <field name="res_model">mobilsoft.cheque.promissory</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
